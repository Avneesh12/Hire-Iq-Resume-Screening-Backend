# ── App ───────────────────────────────────────────────────────────────────────
APP_TITLE=HireIQ API
APP_VERSION=1.0.0
ENV=development

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Used to build the async connection string automatically
DATABASE_URL=postgresql+asyncpg://postgres:Admin123@localhost:5432/hireiq
SYNC_DATABASE_URL=postgresql://postgres:Admin123@localhost:5432/hireiq

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300
ANALYTICS_CACHE_TTL=60

# ── Auth ──────────────────────────────────────────────────────────────────────
# IMPORTANT: change this before deploying — must be a long random string
SECRET_KEY=change-me-to-a-long-random-secret-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list; in development the API allows all origins automatically
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ── Upload limits ─────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10
MAX_BATCH_FILES=50

# ── ML ────────────────────────────────────────────────────────────────────────
MODEL_BASE_DIR=ml_/saved_models
MAX_LEN=100

# ── Celery (background processing) ───────────────────────────────────────────
# Points at Redis by default; change to RabbitMQ URL for production
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
